public class MoveByConflict
{
    public MoveByConflict(ScheduleState state)
    {
        
    }


    improve(schedule):
  for iter in 1..MAX_ITERS:
    w = pickWeekWithConflicts(schedule)
    p = pickOverloadedPerson(schedule[w])
    proj = pickExtraProject(schedule[w][p])   # one of the projects beyond the first

    // 1) Try MOVE to a free person
    candidates = people where schedule[w][person].Count == 0
    if candidates not empty:
        q = chooseBestCandidate(candidates)   // e.g., least utilized across year
        move(w, proj, p -> q)
        continue

    // 2) Try SWAP with a person who has 1 project
    swapCandidates = people where schedule[w][person].Count == 1
    for q in swapCandidates:
        theirProj = only project in schedule[w][q]
        // test if swap reduces conflicts
        if wouldReduceConflicts(w, p, q, proj, theirProj):
            swap(w, p, q, proj, theirProj)
            break
}